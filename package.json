{
  "name": "promptmarket",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "npm --workspace @promptmarket/web run dev",
    "dev:api": "npm --workspace @promptmarket/api run start:dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "seed": "npm --workspace @promptmarket/api run seed",
    "db:push": "npm --workspace @promptmarket/api run db:push",
    "db:generate": "npm --workspace @promptmarket/api run db:generate",
    "shared:build": "npm --workspace @promptmarket/shared run build",
    "shared:dev": "npm --workspace @promptmarket/shared run dev",
    "postinstall": "npm --workspace @promptmarket/shared run build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
