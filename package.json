{
  "name": "promptmarket",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "pnpm --filter @promptmarket/api --filter @promptmarket/web -r --parallel run dev",
    "prepare": "husky",
    "dev:web": "pnpm --filter @promptmarket/web dev",
    "dev:api": "pnpm --filter @promptmarket/api dev",
    "dev:shared": "pnpm --filter @promptmarket/shared dev",
    "build": "pnpm exec turbo run build",
    "clean": "pnpm -r --if-present run clean",
    "ci": "pnpm run format:check && pnpm run lint:ci && pnpm run typecheck && pnpm run test:run && pnpm run build",
    "verify": "pnpm run validate:architecture && pnpm run ci",
    "verify:push": "pnpm run verify && pnpm run lint:security",
    "sonar": "sonar-scanner",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "audit:security": "pnpm audit --audit-level high --ignore GHSA-2p57-rm9w-gvfp",
    "lint:security": "pnpm run lint:strict && pnpm run audit:security",
    "sonar:ci": "sonar-scanner -Dsonar.qualitygate.wait=true",
    "typecheck": "pnpm exec turbo run typecheck",
    "lint": "eslint . && pnpm exec turbo run lint",
    "lint:fix": "eslint . --fix",
    "test": "pnpm exec turbo run test --concurrency=1",
    "test:run": "pnpm -r --if-present run test:run",
    "format": "pnpm -r --if-present run format",
    "format:check": "pnpm -r --if-present run format:check",
    "test:monorepo": "node scripts/verify-pnpm-monorepo.mjs",
    "seed": "pnpm --filter @promptmarket/api seed",
    "db:push": "pnpm --filter @promptmarket/api db:push",
    "db:migrate:deploy": "pnpm --filter @promptmarket/api db:migrate:deploy",
    "db:generate": "pnpm --filter @promptmarket/api db:generate",
    "shared:build": "pnpm --filter @promptmarket/shared build",
    "shared:dev": "pnpm --filter @promptmarket/shared dev",
    "postinstall": "pnpm --filter @promptmarket/shared build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "validate:architecture": "node scripts/validate-architecture.mjs"
  },
  "prettier": "@heejun/prettier-config",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@heejun/eslint-config": "^5.0.0",
    "@heejun/prettier-config": "^3.0.0",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  }
}
