# ── DeskCloud widgets — each is env-gated: a widget renders ONLY when its
# VITE_*DESK_URL is set. Leave all unset (default) to keep the app unaffected
# and fall back to the app's own first-party features. Optional VITE_*DESK_PK
# defaults to "pk_demo" when unset. The example values below are the LIVE
# DeskCloud endpoints — production sets these; nothing is hardcoded in source.

# SurveyDesk — in-app feedback/survey launcher (bottom-left floating widget).
# VITE_SURVEYDESK_URL="https://surveydesk-api.vercel.app"

# ChangelogDesk — in-app "What's new" launcher (bottom-right).
# VITE_CHANGELOGDESK_URL="https://changelogdesk-api.vercel.app"
# VITE_CHANGELOGDESK_PK="pk_demo"

# NotifyDesk — notification bell + inbox. When set, the LIVE NotifyDesk bell
# replaces the app's own static bell IN THE NAVBAR (signed-in users); unset
# falls back to the first-party bell. No separate floating bell is mounted.
# VITE_NOTIFYDESK_URL="https://notifydesk-api.vercel.app"
# VITE_NOTIFYDESK_PK="pk_demo"

# SearchDesk — global search palette. Bound to mod+/ (Ctrl/Cmd + /) so it never
# collides with the app's own catalog-aware ⌘K command palette (a core feature).
# VITE_SEARCHDESK_URL="https://searchdesk-api.vercel.app"
# VITE_SEARCHDESK_PK="pk_demo"

# ReviewDesk — ratings & reviews wall (DeskCloud dock → 리뷰 tab).
# VITE_REVIEWDESK_URL="https://reviewdesk-api.vercel.app"
# VITE_REVIEWDESK_PK="pk_demo"

# CommunityDesk — community board feed (DeskCloud dock → 커뮤니티 tab). NOTE: the
# app ships first-party Community pages (/community); this dock tab is an
# optional secondary feed, not a replacement for the core route.
# VITE_COMMUNITYDESK_URL="https://communitydesk-api.vercel.app"
# VITE_COMMUNITYDESK_PK="pk_demo"

# ModerationDesk — report/abuse button (DeskCloud dock → 신고 tab).
# VITE_MODERATIONDESK_URL="https://16.176.210.195.nip.io/moderation"
# VITE_MODERATIONDESK_PK="pk_demo"

# MediaDesk — media gallery/uploader (DeskCloud dock → 미디어 tab).
# VITE_MEDIADESK_URL="https://16.176.210.195.nip.io/media"
# VITE_MEDIADESK_PK="pk_demo"

# ── Available DeskCloud modules with no matching homegrown feature to replace
# (not wired here; documented for future use). RealtimeDesk = presence/live,
# ChatDesk = DM/group chat. The app's core messaging (/messages) is first-party.
# VITE_REALTIMEDESK_URL="https://16.176.210.195.nip.io/realtime"
# VITE_REALTIMEDESK_PK="pk_demo"
# VITE_CHATDESK_URL="https://16.176.210.195.nip.io/chat"
# VITE_CHATDESK_PK="pk_demo"
