# SurveyDesk feedback widget endpoint — leave unset to disable the widget (default; SurveyDesk not yet deployed)
# VITE_SURVEYDESK_URL="https://surveys.example.com"

# ── DeskCloud widgets — each is env-gated: the widget renders ONLY when its VITE_*_URL is set.
# Leave all unset (default) to keep the app unaffected. Optional VITE_*_PK defaults to "pk_demo".

# ChangelogDesk — in-app "What's new" launcher (bottom-right)
# VITE_CHANGELOGDESK_URL="https://changelog.example.com"
# VITE_CHANGELOGDESK_PK="pk_demo"

# NotifyDesk — notification bell + inbox (top-right; signed-in users only)
# VITE_NOTIFYDESK_URL="https://notify.example.com"
# VITE_NOTIFYDESK_PK="pk_demo"

# SearchDesk — ⌘K / Ctrl+K command palette
# VITE_SEARCHDESK_URL="https://search.example.com"
# VITE_SEARCHDESK_PK="pk_demo"

# ReviewDesk — ratings & reviews (DeskCloud dock → 리뷰 tab)
# VITE_REVIEWDESK_URL="https://reviews.example.com"
# VITE_REVIEWDESK_PK="pk_demo"

# CommunityDesk — community board feed (DeskCloud dock → 커뮤니티 tab)
# VITE_COMMUNITYDESK_URL="https://community.example.com"
# VITE_COMMUNITYDESK_PK="pk_demo"

# ModerationDesk — report button (DeskCloud dock → 신고 tab)
# VITE_MODERATIONDESK_URL="https://moderation.example.com"
# VITE_MODERATIONDESK_PK="pk_demo"

# MediaDesk — media gallery (DeskCloud dock → 미디어 tab)
# VITE_MEDIADESK_URL="https://media.example.com"
# VITE_MEDIADESK_PK="pk_demo"
