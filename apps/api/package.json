{
  "name": "@promptmarket/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "typecheck": "pnpm run db:generate && tsc --noEmit",
    "test": "pnpm run db:generate && vitest",
    "test:run": "pnpm run db:generate && vitest run",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@promptmarket/shared": "workspace:*",
    "argon2": "^0.44.0",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "prisma": "^7.8.0",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
