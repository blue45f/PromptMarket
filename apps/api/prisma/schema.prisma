generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  username      String     @unique
  passwordHash  String?    // null for OAuth-only accounts (e.g. Google sign-in)
  provider      String     @default("local") // "local" | "google"
  googleSub     String?    @unique // Google "sub" claim, set when an account is linked to Google
  isAdmin       Boolean    @default(false)
  bio           String?
  avatarUrl     String?
  balanceCents  Int        @default(0)
  suspendedAt   DateTime?  // set by admins; blocks login + community/marketplace writes
  createdAt     DateTime   @default(now())
  listings      Listing[]
  purchases     Purchase[]
  reviews       Review[]
  reviewReplies ReviewReply[]
  discussionThreads  DiscussionThread[]
  discussionComments DiscussionComment[]
  attachments        Attachment[]
  buyerMessageThreads  MessageThread[] @relation("MessageThreadBuyer")
  sellerMessageThreads MessageThread[] @relation("MessageThreadSeller")
  sentMessages         Message[]
}

model Listing {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  type         String     // ListingType enum (see packages/shared)
  description  String
  body         String
  previewBody  String
  category     String
  tags         String     // comma-separated
  models       String     // comma-separated compat model slugs ("claude-opus-4-7,gpt-5,...")
  technique    String?    // PromptTechnique enum (PROMPT type only)
  difficulty   String     @default("intermediate")  // beginner | intermediate | advanced
  license      String     @default("MIT")
  version      String     @default("1.0.0")
  priceCents   Int        @default(0)
  coverEmoji   String     @default("✨")
  downloads    Int        @default(0)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  purchases    Purchase[]
  reviews      Review[]
  messageThreads MessageThread[]

  @@index([authorId])
  @@index([createdAt])
  @@index([downloads, createdAt])
}

model Purchase {
  id          String   @id @default(cuid())
  userId      String
  listingId   String
  pricePaidCents Int
  sellerNetCents Int
  platformFeeCents Int
  grossAmountCents Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  listing     Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  body      String
  userId    String
  reviewId  String
  deletedAt DateTime? // soft delete — the row stays as a "deleted reply" placeholder
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([userId, createdAt])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  intValue  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5
  comment     String?
  userId      String
  listingId   String
  hiddenAt    DateTime? // set by moderation; hidden reviews drop out of public lists + rating math
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  listing     Listing  @relation(fields: [listingId], references: [id])
  replies     ReviewReply[]
  attachments Attachment[]

  @@unique([userId, listingId])
  @@index([listingId])
}

// ===========================================================================
// Community — per-category discussion boards
// ===========================================================================

model DiscussionThread {
  id        String    @id @default(cuid())
  title     String
  body      String
  category  String    // prompt Category enum (see packages/shared)
  authorId  String
  hiddenAt  DateTime? // set by moderation; hidden threads drop out of public lists
  needsReviewAt DateTime? // set by enabled REVIEW forbidden-word rules
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    DiscussionComment[]
  attachments Attachment[]

  @@index([category, createdAt])
  @@index([authorId, createdAt])
  @@index([needsReviewAt, createdAt])
}

model DiscussionComment {
  id        String    @id @default(cuid())
  body      String
  threadId  String
  authorId  String
  parentId  String?   // one level deep — replies cannot have replies
  deletedAt DateTime? // soft delete — keeps the reply chain shape with a placeholder
  needsReviewAt DateTime? // set by enabled REVIEW forbidden-word rules
  createdAt DateTime  @default(now())
  thread    DiscussionThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    DiscussionComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   DiscussionComment[] @relation("CommentReplies")
  attachments Attachment[]

  @@index([threadId, createdAt])
  @@index([parentId])
  @@index([needsReviewAt, createdAt])
}

model ForbiddenWord {
  id               String   @id @default(cuid())
  phrase           String
  normalizedPhrase String   @unique
  action           String   @default("BLOCK") // BLOCK | REVIEW
  matchType        String   @default("WHOLE_WORD") // WHOLE_WORD | CONTAINS
  enabled          Boolean  @default(true)
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([enabled, action])
  @@index([createdAt])
}

// ===========================================================================
// Direct messages — buyer ↔ seller Q&A scoped to a listing
// ===========================================================================

model MessageThread {
  id        String   @id @default(cuid())
  listingId String
  buyerId   String   // the person who asked (never the listing author)
  sellerId  String   // denormalized listing author for cheap inbox queries
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer     User     @relation("MessageThreadBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller    User     @relation("MessageThreadSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId, updatedAt])
  @@index([sellerId, updatedAt])
}

model Message {
  id        String    @id @default(cuid())
  body      String
  threadId  String
  senderId  String
  readAt    DateTime? // stamped when the counterparty opens the thread
  createdAt DateTime  @default(now())
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// ===========================================================================
// Attachments — resized screenshot images stored as data URLs
// ===========================================================================

model Attachment {
  id         String   @id @default(cuid())
  dataUrl    String   // data:image/...;base64 — client resizes to ≤1600px before upload
  byteSize   Int      // decoded size, server-computed from the base64 payload
  width      Int?
  height     Int?
  uploaderId String
  threadId   String?
  commentId  String?
  reviewId   String?
  createdAt  DateTime @default(now())
  uploader   User               @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  thread     DiscussionThread?  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment    DiscussionComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  review     Review?            @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([commentId])
  @@index([reviewId])
}
