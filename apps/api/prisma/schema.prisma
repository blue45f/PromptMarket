generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  username      String     @unique
  passwordHash  String
  isAdmin       Boolean    @default(false)
  bio           String?
  avatarUrl     String?
  balanceCents  Int        @default(0)
  createdAt     DateTime   @default(now())
  listings      Listing[]
  purchases     Purchase[]
  reviews       Review[]
  reviewReplies ReviewReply[]
}

model Listing {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  type         String     // ListingType enum (see packages/shared)
  description  String
  body         String
  previewBody  String
  category     String
  tags         String     // comma-separated
  models       String     // comma-separated compat model slugs ("claude-opus-4-7,gpt-5,...")
  technique    String?    // PromptTechnique enum (PROMPT type only)
  difficulty   String     @default("intermediate")  // beginner | intermediate | advanced
  license      String     @default("MIT")
  version      String     @default("1.0.0")
  priceCents   Int        @default(0)
  coverEmoji   String     @default("✨")
  downloads    Int        @default(0)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  purchases    Purchase[]
  reviews      Review[]

  @@index([authorId])
  @@index([createdAt])
  @@index([downloads, createdAt])
}

model Purchase {
  id          String   @id @default(cuid())
  userId      String
  listingId   String
  pricePaidCents Int
  sellerNetCents Int
  platformFeeCents Int
  grossAmountCents Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  listing     Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  body      String
  userId    String
  reviewId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([userId, createdAt])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  intValue  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5
  comment     String?
  userId      String
  listingId   String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  listing     Listing  @relation(fields: [listingId], references: [id])
  replies     ReviewReply[]

  @@unique([userId, listingId])
}
